# Server
PORT=4000
ENABLE_CORS=true
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
# Base64-ish example: echo -n "my-secret" | base64
AUTH_KEY=somekey

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/chat_db

# Uploads
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:4000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# S3 uploads (optional)
S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_PUBLIC_READ=false
